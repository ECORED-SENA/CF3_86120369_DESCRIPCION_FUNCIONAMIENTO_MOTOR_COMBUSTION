CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Actividad.vue","sourceRoot":"src/views","sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from 'ecored-pkg-fliz/plugin/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Evaluación de conocimientos',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b> Objetivo:</b> Evaluar el conocimiento adquirido sobre el funcionamiento, ubicación y ajuste de los componentes del sistema de distribución en motores de combustión interna, incluyendo el eje de levas, las válvulas y los diferentes mecanismos de accionamiento.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            '¿Cuál es la función principal del eje de levas en un motor de combustión interna?',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Enfriar el motor.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Regular la presión del aceite.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Aumentar la potencia del motor.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Sincronizar la apertura y cierre de las válvulas.',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto:\n            '¿Qué tipo de sistema de accionamiento del eje de levas es más silencioso y económico?',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Piñones.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Banda dentada.',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Cadena metálica.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Engranajes helicoidales.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto:\n            '¿Cuál de los siguientes componentes NO forma parte del sistema de distribución del motor?',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Válvulas de admisión.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Árbol de levas.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Cigüeñal.',\n              esCorrecta: true,\n            },\n            {\n              id: 'd',\n              texto: 'Balancines.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto:\n            '¿Qué sistema de distribución no requiere mantenimiento durante la vida útil del motor?',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Piñones.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Banda dentada.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Cadena metálica.',\n              esCorrecta: true,\n            },\n            {\n              id: 'd',\n              texto: 'Sistema hidráulico.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto:\n            '¿Qué sucede si la holgura de las válvulas es menor a la recomendada?',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Se puede quemar la cabeza de la válvula.',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Se incrementa la eficiencia del motor.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Disminuye la temperatura del motor.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Aumenta el consumo de combustible.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 6,\n          texto:\n            '¿Cuál es la relación de engranajes entre el cigüeñal y el eje de levas en un motor de cuatro tiempos?',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: '1:1',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: '3:1',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: '2:1',\n              esCorrecta: true,\n            },\n            {\n              id: 'd',\n              texto: '4:1',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 7,\n          texto:\n            '¿Cuál es la ventaja de la propulsión directa de las válvulas en comparación con otros sistemas?',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Aumenta el consumo de combustible.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Es más costoso que los demás sistemas.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Reduce la cantidad de componentes móviles.',\n              esCorrecta: true,\n            },\n            {\n              id: 'd',\n              texto: 'Requiere más mantenimiento.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 8,\n          texto: '¿Cómo se logra la calibración automática de las válvulas?',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Mediante tornillos de ajuste.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Con varillas empujadoras.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Mediante ajuste manual constante.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Utilizando propulsores hidráulicos.',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 9,\n          texto:\n            '¿En qué parte del motor se encuentran las válvulas en un sistema de propulsión directa?',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'En el cárter.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'En el cigüeñal.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'En el sistema de escape.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'En la culata.',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 10,\n          texto:\n            '¿Cuál de estos factores influye en el rendimiento del motor y la apertura de las válvulas?',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Altura y perfil de la leva.',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Temperatura del aceite.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Posición del cigüeñal.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Número de cilindros del motor.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"]}]}